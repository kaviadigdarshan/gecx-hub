{
  "content_filter": {
    "banned_contents": [],
    "banned_in_user_input": [],
    "banned_in_agent_response": ["your passport number", "your credit card number is", "your full card details"],
    "match_type": "CONTAINS",
    "disregard_diacritics": true
  },
  "llm_prompt_security": {
    "use_custom_policy": false,
    "custom_policy_prompt": null,
    "fail_open": false
  },
  "llm_policy": [
    {
      "policy_name": "Booking Commitment Guard",
      "prompt": "Is the agent committing to specific pricing, availability, or room/seat guarantees for a booking without first confirming via the reservations tool? Return VIOLATING if yes.",
      "policy_scope": "AGENT_RESPONSE",
      "max_conversation_messages": 10,
      "allow_short_utterance": true
    }
  ],
  "model_safety": {
    "preset": "BALANCED"
  }
}
