{
  "content_filter": {
    "banned_contents": [],
    "banned_in_user_input": [],
    "banned_in_agent_response": ["ignore this gas leak", "the electrical fault is minor"],
    "match_type": "CONTAINS",
    "disregard_diacritics": true
  },
  "llm_prompt_security": {
    "use_custom_policy": false,
    "custom_policy_prompt": null,
    "fail_open": false
  },
  "llm_policy": [
    {
      "policy_name": "Emergency Deflection Guard",
      "prompt": "Is the user reporting a gas leak, electrical emergency, water main break, or any safety emergency that requires immediate escalation to emergency services? Return VIOLATING so the agent immediately provides emergency contact information.",
      "policy_scope": "USER_INPUT",
      "max_conversation_messages": 10,
      "allow_short_utterance": true
    }
  ],
  "model_safety": {
    "preset": "BALANCED"
  }
}
